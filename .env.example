# Copy to .env (same folder as main.py) and fill in your real key.
# DO NOT commit .env to git.

# Benchmark model (model under test)
API_KEY=
API_BASE=
MODEL_NAME=
TIMEOUT=


# DIAMONDS 8-dim Likert (scripts/annotate_diamonds_items.py); model only from DIAMONDS_MODEL, default claude-sonnet-4-6
# DIAMONDS_MODEL=claude-sonnet-4-6
# Optional overrides; if unset, script falls back to ANNOTATE_API_KEY / API_KEY etc. (see annotate_diamonds_items.py)
# DIAMONDS_API_KEY=
# DIAMONDS_API_BASE=

# assign_scenario_ages_narrative.py (default gpt-5.4-mini; does not use DIAMONDS_MODEL)
# ASSIGN_AGE_MODEL=gpt-5.4-mini
# ASSIGN_AGE_WORKERS=8

# Embedding config (for memory retrieval)
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_MODEL=

# Mem0 intelligent-memory LLM (infer pipeline; default gpt-5.4-mini, independent of MODEL_NAME)
# MEM0_LLM_MODEL=gpt-5.4-mini
# MEM0_LLM_API_KEY=
# MEM0_LLM_BASE_URL=
