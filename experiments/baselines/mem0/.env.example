# Copy to .env and fill in your real keys:
#   cp .env.example .env

# ---- LLM (OpenAI-compatible gateway) ----
API_KEY=sk-your-llm-key-here
API_BASE=<YOUR_LLM_GATEWAY>/v1
LLM_MODEL=gpt-5.4-mini

# ---- Embedding (qwen3-embedding-4b via aihubmix) ----
AIHUBMIX_API_KEY=sk-your-embedding-key-here
AIHUBMIX_API_BASE=https://aihubmix.com/v1
EMBED_MODEL=qwen3-embedding-4b
# Qwen3-Embedding-4B native dimension
EMBED_DIMS=2560
